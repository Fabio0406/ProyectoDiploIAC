{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/orders/src",
  "monorepo": true,
  "root": "apps/orders",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "apps/orders/tsconfig.app.json"
  },
  "projects": {
    "accounts": {
      "type": "application",
      "root": "apps/accounts",
      "entryFile": "main",
      "sourceRoot": "apps/accounts/src",
      "compilerOptions": {
        "webpack": true,
        "tsConfigPath": "apps/accounts/tsconfig.app.json"
      }
    },
    "alerts": {
      "type": "application",
      "root": "apps/alerts",
      "entryFile": "main",
      "sourceRoot": "apps/alerts/src",
      "compilerOptions": {
        "webpack": true,
        "tsConfigPath": "apps/alerts/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "transactions": {
      "type": "application",
      "root": "apps/transactions",
      "entryFile": "main",
      "sourceRoot": "apps/transactions/src",
      "compilerOptions": {
        "webpack": true,
        "tsConfigPath": "apps/transactions/tsconfig.app.json"
      }
    }
  }
}
